{{ 'izamarck-product-page.css' | asset_url | stylesheet_tag }}

<div class="izm-product-page">
  <div class="izm-product-page__container">
    <div class="izm-product-page__grid">
      {%- comment -%} Product Images {%- endcomment -%}
      <div class="izm-product-page__images">
        <div class="izm-product-page__main-image" id="main-product-image">
          {% if product.featured_image %}
            {{ product.featured_image | image_url: width: 1200 | image_tag: 
              alt: product.title,
              id: 'main-image'
            }}
          {% endif %}
        </div>

        {% if product.images.size > 1 %}
          <div class="izm-product-page__thumbnails">
            {% for image in product.images limit: 4 %}
              <div class="izm-product-page__thumbnail {% if forloop.first %}izm-product-page__thumbnail--active{% endif %}" onclick="changeMainImage('{{ image | image_url: width: 1200 }}', this)">
                {{ image | image_url: width: 300 | image_tag: alt: product.title }}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {%- comment -%} Product Info {%- endcomment -%}
      <div class="izm-product-page__info">
        <div class="izm-product-page__breadcrumb">
          <a href="/">Inicio</a> / 
          <a href="/collections/{{ product.collections.first.handle }}">{{ product.collections.first.title }}</a> / 
          {{ product.title }}
        </div>

        <h1 class="izm-product-page__title">{{ product.title }}</h1>

        {% if product.vendor != blank %}
          <p class="izm-product-page__vendor">{{ product.vendor }}</p>
        {% endif %}

        <div class="izm-product-page__price">
          <span class="izm-product-page__price-current {% if product.compare_at_price > product.price %}izm-product-page__price-current--sale{% endif %}">
            {{ product.price | money }}
          </span>
          {% if product.compare_at_price > product.price %}
            <span class="izm-product-page__price-original">
              {{ product.compare_at_price | money }}
            </span>
            <span class="izm-product-page__badge">
              -{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
            </span>
          {% endif %}
        </div>

        {%- form 'product', product, id: 'product-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {%- comment -%} Product Options {%- endcomment -%}
          {% unless product.has_only_default_variant %}
            <div class="izm-product-page__options">
              {% for option in product.options_with_values %}
                <div class="izm-product-page__option">
                  <label class="izm-product-page__option-label">
                    {{ option.name }}: 
                    <span id="selected-{{ option.name | handleize }}">{{ option.selected_value }}</span>
                  </label>
                  <div class="izm-product-page__option-values">
                    {% for value in option.values %}
                      <button 
                        type="button"
                        class="izm-product-page__option-btn {% if option.selected_value == value %}izm-product-page__option-btn--active{% endif %}"
                        onclick="selectOption('{{ option.name | handleize }}', '{{ value }}', this)"
                        data-option="{{ option.name | handleize }}"
                        data-value="{{ value }}"
                      >
                        {{ value }}
                      </button>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endunless %}

          {%- comment -%} Quantity & Add to Cart {%- endcomment -%}
          <div class="izm-product-page__actions">
            <div class="izm-product-page__quantity">
              <span class="izm-product-page__quantity-label">Cantidad:</span>
              <div class="izm-product-page__quantity-selector">
                <button type="button" class="izm-product-page__quantity-btn" onclick="updateQuantity(-1)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </button>
                <input 
                  type="number" 
                  name="quantity" 
                  value="1" 
                  min="1"
                  class="izm-product-page__quantity-input"
                  id="quantity-input"
                >
                <button type="button" class="izm-product-page__quantity-btn" onclick="updateQuantity(1)">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </button>
              </div>
            </div>

            <button 
              type="submit" 
              name="add"
              class="izm-product-page__add-to-cart"
              {% unless product.available %}disabled{% endunless %}
            >
              {% if product.available %}
                Añadir al carrito
              {% else %}
                Agotado
              {% endif %}
            </button>
          </div>
        {%- endform -%}

        {%- comment -%} Product Description {%- endcomment -%}
        {% if product.description != blank %}
          <div class="izm-product-page__description">
            <h3 class="izm-product-page__description-title">Descripción</h3>
            <div class="izm-product-page__description-content">
              {{ product.description }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  // Change main image
  function changeMainImage(imageUrl, thumbnail) {
    const mainImage = document.getElementById('main-image');
    mainImage.src = imageUrl;
    
    // Update active thumbnail
    document.querySelectorAll('.izm-product-page__thumbnail').forEach(el => {
      el.classList.remove('izm-product-page__thumbnail--active');
    });
    thumbnail.classList.add('izm-product-page__thumbnail--active');
  }

  // Update quantity
  function updateQuantity(delta) {
    const input = document.getElementById('quantity-input');
    const currentValue = parseInt(input.value) || 1;
    const newValue = Math.max(1, currentValue + delta);
    input.value = newValue;
  }

  // Select option
  function selectOption(optionName, value, button) {
    // Update UI
    const optionButtons = button.parentElement.querySelectorAll('.izm-product-page__option-btn');
    optionButtons.forEach(btn => btn.classList.remove('izm-product-page__option-btn--active'));
    button.classList.add('izm-product-page__option-btn--active');
    
    // Update selected value display
    const selectedDisplay = document.getElementById(`selected-${optionName}`);
    if (selectedDisplay) {
      selectedDisplay.textContent = value;
    }
    
    // Update variant (simplified - would need variant selection logic in production)
    updateVariant();
  }

  // Update variant based on selected options
  function updateVariant() {
    // This is a simplified version
    // In production, you'd match selected options to available variants
    console.log('Variant updated');
  }

  // Handle form submission
  const form = document.getElementById('product-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const formData = new FormData(form);
      
      fetch('/cart/add.js', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(data => {
        // Update cart count
        fetch('/cart.js')
          .then(res => res.json())
          .then(cart => {
            document.dispatchEvent(new CustomEvent('cart:update', { detail: { cart } }));
            updateCartCount(cart.item_count);
          });
        
        alert('Producto añadido al carrito');
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error al añadir al carrito');
      });
    });
  }
</script>

{% schema %}
{
  "name": "Izamarck Product Page",
  "settings": []
}
{% endschema %}
