{{ 'izamarck-footer.css' | asset_url | stylesheet_tag }}

<footer class="izm-footer">
  {%- comment -%} Announcement Ticker {%- endcomment -%}
  <div class="izm-footer__ticker">
    <div class="izm-footer__ticker-wrap">
      {% for i in (1..8) %}
        <span class="izm-footer__ticker-item">
          {{ section.settings.ticker_text | default: 'UNA COMUNIDAD DEDICADA AL DISFRUTE Y RESPETO A LA MODA · IZAMARCK ·' }}
        </span>
      {% endfor %}
    </div>
  </div>

  <div class="izm-footer__content">
    {%- comment -%} Logo Section {%- endcomment -%}
    <div class="izm-footer__logo-section">
      <a href="{{ routes.root_url }}" class="izm-footer__logo">
        IZAMARCK
      </a>
      <p class="izm-footer__tagline">{{ section.settings.tagline | default: 'Moda con identidad' }}</p>
    </div>

    {%- comment -%} Social Icons {%- endcomment -%}
    <div class="izm-footer__social">
      {% if section.settings.instagram_url != blank %}
        <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" class="izm-footer__social-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.facebook_url != blank %}
        <a href="{{ section.settings.facebook_url }}" aria-label="Facebook" class="izm-footer__social-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.twitter_url != blank %}
        <a href="{{ section.settings.twitter_url }}" aria-label="X / Twitter" class="izm-footer__social-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.youtube_url != blank %}
        <a href="{{ section.settings.youtube_url }}" aria-label="YouTube" class="izm-footer__social-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
            <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.tiktok_url != blank %}
        <a href="{{ section.settings.tiktok_url }}" aria-label="TikTok" class="izm-footer__social-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.54V6.78a4.85 4.85 0 01-1.02-.09z"/>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.spotify_url != blank %}
        <a href="{{ section.settings.spotify_url }}" aria-label="Spotify" class="izm-footer__social-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.623.623 0 01-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 11-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 01.207.857zm1.223-2.722a.78.78 0 01-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 01-.971-.519.781.781 0 01.519-.972c3.632-1.102 8.147-.568 11.233 1.328a.78.78 0 01.256 1.072zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 11-.543-1.794c3.503-1.062 9.33-.857 13.004 1.329a.937.937 0 01-.844 1.622z"/>
          </svg>
        </a>
      {% endif %}
    </div>

    {%- comment -%} Footer Columns {%- endcomment -%}
    <div class="izm-footer__columns">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          <h4 class="izm-footer__column-title">{{ block.settings.title }}</h4>
          <ul class="izm-footer__column-list">
            {% if block.settings.link_1_text != blank %}
              <li class="izm-footer__column-item">
                {% if block.settings.link_1_url != blank %}
                  <a href="{{ block.settings.link_1_url }}" class="izm-footer__column-link">{{ block.settings.link_1_text }}</a>
                {% else %}
                  <span class="izm-footer__column-text">{{ block.settings.link_1_text }}</span>
                {% endif %}
              </li>
            {% endif %}
            {% if block.settings.link_2_text != blank %}
              <li class="izm-footer__column-item">
                {% if block.settings.link_2_url != blank %}
                  <a href="{{ block.settings.link_2_url }}" class="izm-footer__column-link">{{ block.settings.link_2_text }}</a>
                {% else %}
                  <span class="izm-footer__column-text">{{ block.settings.link_2_text }}</span>
                {% endif %}
              </li>
            {% endif %}
            {% if block.settings.link_3_text != blank %}
              <li class="izm-footer__column-item">
                {% if block.settings.link_3_url != blank %}
                  <a href="{{ block.settings.link_3_url }}" class="izm-footer__column-link">{{ block.settings.link_3_text }}</a>
                {% else %}
                  <span class="izm-footer__column-text">{{ block.settings.link_3_text }}</span>
                {% endif %}
              </li>
            {% endif %}
            {% if block.settings.link_4_text != blank %}
              <li class="izm-footer__column-item">
                {% if block.settings.link_4_url != blank %}
                  <a href="{{ block.settings.link_4_url }}" class="izm-footer__column-link">{{ block.settings.link_4_text }}</a>
                {% else %}
                  <span class="izm-footer__column-text">{{ block.settings.link_4_text }}</span>
                {% endif %}
              </li>
            {% endif %}
            {% if block.settings.link_5_text != blank %}
              <li class="izm-footer__column-item">
                {% if block.settings.link_5_url != blank %}
                  <a href="{{ block.settings.link_5_url }}" class="izm-footer__column-link">{{ block.settings.link_5_text }}</a>
                {% else %}
                  <span class="izm-footer__column-text">{{ block.settings.link_5_text }}</span>
                {% endif %}
              </li>
            {% endif %}
          </ul>
        </div>
      {% endfor %}
    </div>

    {%- comment -%} Newsletter {%- endcomment -%}
    {% if section.settings.show_newsletter %}
      <div class="izm-footer__newsletter">
        <div class="izm-footer__newsletter-wrap">
          <div>
            <p class="izm-footer__newsletter-title">Newsletter</p>
            <p class="izm-footer__newsletter-desc">{{ section.settings.newsletter_text | default: 'Suscríbete y recibe un 10% en tu primera compra.' }}</p>
          </div>
          <form method="post" action="/contact#contact_form" id="contact_form" accept-charset="UTF-8" class="izm-footer__newsletter-form">
            <input type="hidden" name="form_type" value="customer">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input 
              type="email" 
              name="contact[email]" 
              placeholder="Tu correo electrónico" 
              class="izm-footer__newsletter-input"
              required
            >
            <button type="submit" class="izm-footer__newsletter-btn">OK</button>
          </form>
        </div>
      </div>
    {% endif %}

    {%- comment -%} Bottom {%- endcomment -%}
    <div class="izm-footer__bottom">
      <p class="izm-footer__copyright">{{ section.settings.copyright | default: '© 2026 IZAMARCK®. Todos los derechos reservados.' }}</p>
      <div class="izm-footer__legal">
        {% if section.settings.privacy_url != blank %}
          <a href="{{ section.settings.privacy_url }}" class="izm-footer__legal-link">Privacidad</a>
        {% endif %}
        {% if section.settings.cookies_url != blank %}
          <a href="{{ section.settings.cookies_url }}" class="izm-footer__legal-link">Cookies</a>
        {% endif %}
        {% if section.settings.legal_url != blank %}
          <a href="{{ section.settings.legal_url }}" class="izm-footer__legal-link">Legal</a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Izamarck Footer",
  "settings": [
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Ticker Text",
      "default": "UNA COMUNIDAD DEDICADA AL DISFRUTE Y RESPETO A LA MODA · IZAMARCK ·"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Moda con identidad"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter/X URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "spotify_url",
      "label": "Spotify URL"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show Newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Description",
      "default": "Suscríbete y recibe un 10% en tu primera compra."
    },
    {
      "type": "header",
      "content": "Bottom"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright Text",
      "default": "© 2026 IZAMARCK®. Todos los derechos reservados."
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy Policy URL"
    },
    {
      "type": "url",
      "id": "cookies_url",
      "label": "Cookies Policy URL"
    },
    {
      "type": "url",
      "id": "legal_url",
      "label": "Legal URL"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Footer Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Title",
          "default": "Column Title"
        },
        {
          "type": "text",
          "id": "link_1_text",
          "label": "Link 1 Text"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Link 1 URL"
        },
        {
          "type": "text",
          "id": "link_2_text",
          "label": "Link 2 Text"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Link 2 URL"
        },
        {
          "type": "text",
          "id": "link_3_text",
          "label": "Link 3 Text"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_text",
          "label": "Link 4 Text"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        },
        {
          "type": "text",
          "id": "link_5_text",
          "label": "Link 5 Text"
        },
        {
          "type": "url",
          "id": "link_5_url",
          "label": "Link 5 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Izamarck Footer",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "title": "Sobre la Marca",
            "link_1_text": "Sobre Nosotros",
            "link_2_text": "Nuestra Historia",
            "link_3_text": "Cultura IZAMARCK",
            "link_4_text": "Trabaja con Nosotros",
            "link_5_text": "La Vida en IZAMARCK"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "Ayuda",
            "link_1_text": "Cambios, Devoluciones y Garantías",
            "link_2_text": "Términos y Condiciones",
            "link_3_text": "Política de Envíos",
            "link_4_text": "Preguntas Frecuentes",
            "link_5_text": "Escríbenos"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "Contacto",
            "link_1_text": "NIT: 000.000.000-0",
